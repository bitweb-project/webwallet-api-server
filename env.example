# .env.example — copy to .env and fill in your values
# chmod 600 .env   (readable only by the service user)

# Flask secret key — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Server bind settings (Gunicorn)
HOST=0.0.0.0
PORT=21223
DEBUG=false

# ElectrumX connection
ELECTRUM_HOST=electrumx.example.com
ELECTRUM_PORT=20002
ELECTRUM_TIMEOUT=15
ELECTRUM_VERIFY_SSL=true
ELECTRUM_POOL_SIZE=4

# Fee reported by /fee endpoint (satoshis)
FIXED_FEE_SATOSHIS=10000
